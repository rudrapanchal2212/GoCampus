# MongoDB Connection String (Atlas URI)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.abc.mongodb.net/campus_event_db?retryWrites=true&w=majority

# JWT Secret Key
JWT_SECRET=any_strong_random_string

# Email Configuration (for Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Port
PORT=5000

# Frontend URL (for CORS protection)
# Set this to your Vercel URL in production
FRONTEND_URL=http://localhost:5173

# Node Environment
NODE_ENV=development
